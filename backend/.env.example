# 后端环境变量示例
# 复制此文件为 .env 并根据实际情况修改

# FastAPI 服务监听地址
HOST=0.0.0.0
# FastAPI 服务端口
PORT=5000

# CORS 允许的前端源地址（多个用逗号分隔）
CORS_ORIGINS=http://localhost:5101,http://127.0.0.1:5101,http://localhost:5102,http://127.0.0.1:5102

# 数据库连接 URL（SQLite 示例）
DATABASE_URL=sqlite:///../data/ferment.db

# 运行模式：development / production
ENVIRONMENT=development
