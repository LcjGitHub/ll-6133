# 家庭发酵实验日志 — 环境变量示例
# 复制此文件为 .env 并根据实际情况修改配置

# ===== 后端服务配置 =====
# 后端 FastAPI 服务监听地址
BACKEND_HOST=0.0.0.0
# 后端 FastAPI 服务端口
BACKEND_PORT=5000
# CORS 允许的前端源地址（多个用逗号分隔）
BACKEND_CORS_ORIGINS=http://localhost:5101,http://127.0.0.1:5101,http://localhost:5102,http://127.0.0.1:5102
# SQLite 数据库文件路径（相对于 backend 目录）
DATABASE_URL=sqlite:///../data/ferment.db

# ===== 前端接口地址配置 =====
# 前端 Vite 开发服务器端口
VITE_PORT=5101
# 前端调用后端 API 的基础地址（Vite 环境变量需以 VITE_ 开头）
VITE_API_BASE_URL=http://localhost:5000/api
